{
  "name": "filefront-arena",
  "version": "0.1.1",
  "description": "A real-time multiplayer CLI file attack-and-defense arena.",
  "type": "module",
  "bin": {
    "filefront": "src/cli.js"
  },
  "files": [
    "README.md",
    "scripts/",
    "src/"
  ],
  "scripts": {
    "server": "node src/server/index.js",
    "client": "node src/client/index.js",
    "client:split": "node scripts/open-split-client.mjs",
    "join": "node scripts/join-client.mjs",
    "join:split": "node scripts/open-split-client.mjs",
    "config": "node scripts/config.mjs",
    "setup": "node scripts/setup.mjs",
    "bootstrap": "node scripts/setup.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=20"
  }
}
